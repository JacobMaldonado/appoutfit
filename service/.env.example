# Environment: local | dev | prod
ENV=local

# Google Gemini API key (not required in local env)
GEMINI_API_KEY=

# Black Forest Labs Flux API key (not required in local env)
BFL_API_KEY=

# Firebase project ID (not required in local env)
FIREBASE_PROJECT_ID=

# Firebase Storage bucket name, e.g. "my-project.firebasestorage.app"
# Find it in Firebase Console → Storage → gs://... (omit the gs:// prefix)
FIREBASE_STORAGE_BUCKET=

# Firebase service account — either an absolute path to a JSON file
# or a base-64-encoded JSON string (not required in local env)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloud Scheduler service account email for OIDC verification
# (not required in local env)
BATCH_SCHEDULER_SA_EMAIL=

# Port (injected automatically by Cloud Run in deployed environments)
PORT=8080
